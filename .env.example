# From Supabase: Project Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Any long random string — used to sign trip session tokens.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Gates creating and deleting trips (separate from each trip's own password,
# which friends use to view/edit that trip). Keep this out of anywhere public.
MASTER_PASSWORD=SuperPsyduckSquad?!?!
